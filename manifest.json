{
  "manifest_version": 3,
  "name": "Site Analyzer",
  "version": "2.0.0",
  "description": "Smart website analyzer: detects active sites, parked domains, landing pages, and errors.",
  "permissions": ["activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}